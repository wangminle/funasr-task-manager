# ============================================================
# ASR Task Manager — 生产环境配置模板
# 复制为 .env 并按实际情况修改
# ============================================================

# --- 应用 ---
ASR_DEBUG=false
ASR_LOG_LEVEL=INFO
ASR_LOG_FORMAT=json

# --- 认证 (生产环境必须启用) ---
ASR_AUTH_ENABLED=true
# 格式: user_id:token,user_id:token,...
# 请使用随机生成的强 Token（至少 32 字符）
ASR_AUTH_TOKENS=admin:CHANGE_ME_ADMIN_TOKEN_32CHARS_MIN,user1:CHANGE_ME_USER1_TOKEN_32CHARS_MIN

# --- CORS (限制为前端实际域名) ---
# 多个域名用逗号分隔；生产环境不要使用 *
ASR_CORS_ORIGINS=https://asr.example.com,https://admin.example.com

# --- 项目根目录 (Docker 镜像已内置，通常不需要手动设置) ---
# ASR_PROJECT_ROOT=/app

# --- 数据库 ---
# SQLite (单实例，默认会使用 ASR_STORAGE_ROOT/asr_tasks.db):
ASR_STORAGE_ROOT=/app/runtime/storage
ASR_LOG_DIR=/app/runtime/logs
# 如需显式指定 SQLite：
# ASR_DATABASE_URL=sqlite+aiosqlite:////app/runtime/storage/asr_tasks.db
# PostgreSQL (高并发/多实例):
# ASR_DATABASE_URL=postgresql+asyncpg://user:password@db-host:5432/asr_tasks

# --- Redis (多实例部署时启用) ---
ASR_REDIS_URL=redis://redis:6379/0

# --- 存储 ---
# 如需覆盖默认目录，可显式指定：
# ASR_UPLOAD_DIR=/app/runtime/storage/uploads
# ASR_RESULT_DIR=/app/runtime/storage/results
# ASR_TEMP_DIR=/app/runtime/storage/temp
ASR_MAX_UPLOAD_SIZE_MB=2048

# --- 任务 ---
ASR_TASK_TIMEOUT_SECONDS=3600
ASR_MAX_RETRY_COUNT=3

# --- 心跳 ---
ASR_HEARTBEAT_INTERVAL_SECONDS=30
ASR_HEARTBEAT_TIMEOUT_SECONDS=90
